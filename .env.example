# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dondever

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# TheSportsDB (optional, for TV channel data)
SPORTSDB_API_KEY=1

# App
APP_URL=https://dondever.app
SECRET_KEY=change-this-to-random-secret

# Analytics (optional — leave blank to disable)
# Google Tag Manager container ID (format: GTM-XXXXXXX). Recommended — lets you
# add GA4, Clarity, Facebook Pixel, etc. from the GTM web UI without code changes.
GTM_CONTAINER_ID=
# GA4 Measurement ID (format: G-XXXXXXXXXX). Only set this if you want GA4 directly,
# without going through GTM. If GTM_CONTAINER_ID is set, configure GA4 inside GTM instead.
GA_MEASUREMENT_ID=
# Microsoft Clarity Project ID, get it from clarity.microsoft.com -> Settings -> Setup
CLARITY_PROJECT_ID=

# Affiliate Links
AFFILIATE_BETSSON=https://record.betsson.com/_your_id
AFFILIATE_CJ=https://www.anrdoezrs.net/click-your_id
